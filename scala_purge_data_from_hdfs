package com.scb.cib

import scala.io.Source
import org.apache.log4j._
import org.apache.spark.rdd.RDD
import org.apache.spark.sql.DataFrame
import org.apache.spark.sql.hive.HiveContext
import org.apache.spark.{SparkConf, SparkContext}
import org.joda.time.{DateTimeConstants, Days, LocalDate, DateTime}
import org.joda.time.format.DateTimeFormat
import org.apache.spark.sql.functions._
import java.io.{FileNotFoundException, IOException}
import org.apache.hadoop.fs.{FileSystem, Path}
import org.apache.hadoop.conf.Configuration
import org.apache.spark.sql.expressions.Window
import org.apache.spark.sql.functions.row_number


object pkCDLDataPurge {
  
  val LOGGER = Logger.getLogger("DATA PURGING PK-CDL ")
  Logger.getLogger("org").setLevel(Level.OFF);
  Logger.getLogger("akka").setLevel(Level.OFF);
  
  def main(args: Array[String]) {
    
    //spark context and hive context
    val conf = new SparkConf().setAppName("MasterTableDataPurge")
    val sc = new SparkContext(conf)
    val hc = new HiveContext(sc)
    
    //Create new hdfs object to be used in File operations
    val hadoopConf = new Configuration()
    val hdfs = FileSystem.get(hadoopConf)
    
    LOGGER.info(" : Feching the input parameters : ")
    
    var inputFile = ""
    var copyDate = ""
    var retention = 0
    var hdfsPath = ""
    
    //check for parameters passed 
    if (args.size.equals(4)){
      
      inputFile = args(0)
      copyDate  = args(1)
      retention = args(2).toInt
      hdfsPath = args(3)
      
      LOGGER.info(" : Source file for the details : " + inputFile)
      LOGGER.info(" : Data copy date : " + copyDate)
      LOGGER.info(" : retention time freame : " + retention)
      LOGGER.info(" : HDFS path for the  : " + hdfsPath)
      
      } else {
        
        LOGGER.error(" : Please pass the required arguments to the job ")
        LOGGER.error(" : Insufficient arguments passed to the job ")
        LOGGER.error(s"""spark-submit --class <{COOL_SPARK_JOB_CLASS_NAME}> --master yarn --driver-memory <{SPARK_DRIVER_MEMORY}> 
                         --executor-cores <{SPARK_NUM_CORES}> --executor-memory <{SPARK_EXEC_MEMORY}> --num-executors <{SPARK_NUM_EXECUTORS}> 
                         --conf spark.port.maxRetries=50 --conf spark.sql.shuffle.partitions=<{SPARK_SHUFFLE_PARTITIONS}> 
                         --conf spark.default.parallelism=<{SPARK_DEFAULT_PARALLELISM}> --jars <{HIVE_JARS_PATH}> <{jar_path}>/<{SL_JAR_NAME}> 
                         inputFile ${args(0)} copyDate ${args(1)} retention ${args(2)} hdfsPath ${args(3)}""")
        sys.exit(1)
        
      }
    
    //execute hive query
    def executeQuery(hc: HiveContext, query: String): DataFrame = {
    try {
      hc.sql(query)
    } catch {
      case e: Exception => LOGGER.error(" : Got an exception while running query : " + query + "exception : " + e);null}
    }
    
    //check if received date is month end date
    def checkMonthEnd(partitionDate: String): Boolean = {
      
      //Fetch length year month and Day of sate
      val dateLength = partitionDate.length()
      val dateSeparator = partitionDate(4)
      val dateYear = partitionDate.split(dateSeparator)(0)
      val dateMonth = partitionDate.split(dateSeparator)(1)
      val dateDay = partitionDate.split(dateSeparator)(2)
      
      //preparing unformatted date
      val unformatedDate = dateYear + dateMonth + dateDay
      LOGGER.info("Lenth of partition date : " + dateLength + " Year of partition " + dateYear + " Month of partition " + dateMonth + " Day of partition " + dateDay)
      
      //date formatting
      val inputFormatter = DateTimeFormat.forPattern("yyyyMMdd")
      val dateOfPartition = inputFormatter.parseDateTime(unformatedDate)
      val monthEndDate = dateOfPartition.dayOfMonth().withMaximumValue().toString("yyyyMMdd")
      
      //compare month end date with current partition
      if (unformatedDate == monthEndDate) {
        LOGGER.info("Month End partition unformatedDate " + unformatedDate +" month end Date " + monthEndDate + " partitionDate " + partitionDate)
        return true
      } else {
        LOGGER.info("Not a month end partition " + unformatedDate +" month end Date " + monthEndDate + " partitionDate " + partitionDate)
        return false
      }
    }
  
    
    //preparation of input file path
    var InputTableFile = hdfsPath + "/" + inputFile
    var lines = List[String]()
    
    LOGGER.info(" : Reading table list from  : " + InputTableFile)
    
    try {
      lines = sc.textFile(InputTableFile).collect.toList
    } catch {
      case e: FileNotFoundException => {LOGGER.error(" : could not find the file : " + InputTableFile + "exception : " + e); null} 
      case e: IOException => {LOGGER.error(" : Got an IOException in file : " + InputTableFile + "exception : " + e); null}
      case _: Exception => {LOGGER.error(" : Got an unexpected exception while reading the file : " + InputTableFile ); null} 
      }


    //starting the data movement
    for (line <- lines) {
      
      val dataBase = line.split('.')(0)
      val sourceTable = line.split('.')(1)
      
      val partitionQuery= s"show partitions ${dataBase}.${sourceTable}"
      LOGGER.info(" : Fetching partitions from table : " + dataBase + "." + sourceTable)
      
      val partitions = executeQuery(hc: HiveContext, partitionQuery).select("partition").orderBy(desc("partition")).collect().map(_(0).toString()).toList
      LOGGER.info(" : Starting the process to remove old partition from table : " + sourceTable)
      
      var count = 0
      for (i <- partitions) {
        
        
        val partitionValue = i.split('=')(0)
        val partitionDate = i.split('=')(1)
        count = count + 1
        LOGGER.info("=========================================================================== ")
        
        val lengthOfDate = partitionDate.length()
        val separatorCount = partitionDate.count(_ == partitionDate(4))
        LOGGER.info(" : Partitions details : " + i + " length Of Partition " + lengthOfDate + " Separator Count : " + separatorCount)
        if (lengthOfDate < 10 || separatorCount < 2) {LOGGER.info(" : Invalid Partition : " + i + " length Of Partition " + lengthOfDate + " Separator Count : " + separatorCount)}
        
        if (count > retention && lengthOfDate >= 10 && separatorCount >= 2) {
          
          val monthEndPartition = checkMonthEnd(partitionDate)
          
          if (monthEndPartition) {
            LOGGER.info(" : Month end partition hence skipping this ")
          } else {
            
            val removePartition = s"alter table ${dataBase}.${sourceTable} drop if exists partition (${partitionValue}='${partitionDate}')"
            executeQuery(hc: HiveContext, removePartition)
            LOGGER.info(" : Remove partition : " + i + " from table " + sourceTable + " count : " + count)
            
            
            val hadfsTablePartition = hdfsPath + "/" + dataBase + "/" + sourceTable + "/" + i
            LOGGER.info(" : Remove HDFS partition : " + hadfsTablePartition)
            
            if (hdfs.exists(new Path(hadfsTablePartition))) {
              hdfs.delete(new Path(hadfsTablePartition), true)
            } else {
              LOGGER.info(" : partion do not exist in HDFS : " + hadfsTablePartition)
            }
            }
          } else {LOGGER.info(" : not removing partition number : " + i + " count : " + count + " retention : " + retention)}
        
        LOGGER.info("=========================================================================== ")
      }
     
    }
    
  }
  
}
