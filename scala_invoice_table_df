      //function to fetch and join otp1 data
      def joinGlobalCountryData1(otpCountryData: otpData1, glbData:globalData1, cty: String): DataFrame ={
        
        //country Tables
        val dealHist = otpCountryData._1
        val docDtls = otpCountryData._2
        val party = otpCountryData._3
        val country = cty.toUpperCase()
        val zero = 0
        val space = " "
        
        var cty2 = country
        if( country == "SP" ) {
          cty2 = "SG" 
          } else {
            cty2 = country
            }
        
        //global tables
        val scidata = glbData._1
        val mainprof = glbData._2
        val groupRates = glbData._3
        val cmtData = glbData._4
       
        //joining otp tables
        LOGGER.info("Joining OTP tables data")
        val otpdata = dealHist.join(docDtls, dealHist("deal_rec_id") === docDtls("deal_rec_id")
                                  && dealHist("cty_code") === docDtls("cty_code"), "inner")
                              .join(party, dealHist("deal_rec_id") === party("deal_rec_id")
                                  && dealHist("ct_pty_Id") === party("party_id"), "left")
                                                                      
        //joining otp and sci data
        LOGGER.info("Joining otp and sci tables data")
        val otpSciJoin = otpdata.join(scidata, otpdata("cust_id") === scidata("lsx_ext_sys_cust_id")
                                 && scidata.col("lsx_ext_sys_cd_val") === "OAF" && scidata.col("bkl_cntry_iso_cd") === country, "left")
                                                                  

        //joining with resulted data with currency and rate table
        LOGGER.info("Joining resulted data with surrency and rate table")                                   
        val invoiceData = otpSciJoin.join(mainprof, otpSciJoin("lsx_le_id") === mainprof("lmp_sys_gen_le_id"), "left")
                                    .join(groupRates, docDtls("doc_ccy_code") === groupRates("sc_cury")
                                        && groupRates.col("row_num") === 1,"left")
                                    .join(cmtData, scidata("lsx_le_id") === cmtData("le_id") 
                                        && scidata.col("lsx_ext_sys_cd_val") === "OAF" && scidata.col("bkl_cntry_iso_cd") === country, "left")
                                        
        //this step will select only required columns
        LOGGER.info("selecting only required columns")        
        val finalData1 = invoiceData.select(dealHist.col("cust_id"), 
                       concat(scidata.col("lsx_le_id"), lit("-"), scidata.col("lsx_lsp_id")),
                       scidata.col("lsx_ext_sys_cust_nm"), 
                       mainprof.col("lmp_new_segmt_val"), 
                       mainprof.col("lmp_sub_sgmnt_cd_val"), 
                       dealHist.col("supplier_id"), 
                       dealHist.col("buyer_id"), 
                       dealHist.col("product_code"),
                       substring(dealHist.col("value_date"),0,10),
                       substring(dealHist.col("business_date"),0,10), 
                       docDtls.col("deal_rec_id"),
                       docDtls.col("doc_id"), 
                       docDtls.col("doc_no").alias("invoice_reference"),  
                       substring(docDtls.col("doc_date"),0,10), 
                       docDtls.col("doc_ccy_code"), 
                       docDtls.col("doc_ccy_amt"), 
                       groupRates.col("sc_cash"), 
                       when(docDtls.col("doc_ccy_code") === "USD", docDtls.col("doc_ccy_amt")).otherwise(docDtls.col("doc_ccy_amt") / coalesce(groupRates.col("sc_cash"),lit(1))).alias("invoice_amount_usd"),
                       docDtls.col("doc_type"),
                       docDtls.col("ship_mode"), 
                       docDtls.col("ship_doc_type_code"), 
                       docDtls.col("ship_doc_no"), 
                       docDtls.col("ship_date"), 
                       docDtls.col("ship_from"), 
                       docDtls.col("ship_to"), 
                       docDtls.col("vessel_id"), 
                       docDtls.col("goods_desc"), 
                       dealHist.col("ct_pty_Id"), 
                       party.col("party_name"),
                       row_number().over(Window.partitionBy(dealHist.col("cty_code"), dealHist.col("buyer_id"), dealHist.col("supplier_id"), docDtls.col("doc_no")).orderBy(docDtls.col("doc_id").asc)).alias("submission_num"),
                       cmtData.col("sc_final_appr_crg").alias("credit_grade"), 
                       lit("XXXXXXXXXX").alias("alert_type"),
                       docDtls.col("tenor"),
                       dealHist.col("mode_of_submission"),
                       dealHist.col("step_code"),
                       dealHist.col("pool_based_flag"), 
                       dealHist.col("sale_ledger_flag"),
                       lit(space).alias("invoice_pattern"),
                       lit(zero).alias("pattern_count"),
                       dealHist.col("report_mth"), 
                       lit(cty2).alias("cty")).distinct()
                      
        return (finalData1) 
      }
      
      
      //function to fetch and join otp2 data
      def joinGlobalCountryData2(otpCountryData: otpData2, glbData:globalData1, cty: String): DataFrame ={
        
          //country Tables
          val dealHist2 = otpCountryData._1
          val docProc =  otpCountryData._2
          val docAddl = otpCountryData._3
          val docShip = otpCountryData._4
          val docKey = otpCountryData._5
          val party = otpCountryData._6
          val country = cty.toUpperCase()
          val zero = 0
          val space = " "
          
          var cty2 = country
          if( country == "SP" ) {
            cty2 = "SG" 
            } else {
              cty2 = country
            }
          
          //global tables
          val scidata = glbData._1
          val mainprof = glbData._2
          val groupRates = glbData._3
          val cmtData = glbData._4
                    
          //joining otp tables
          LOGGER.info("Joining OTP tables data")
          val otpdata = dealHist2.join(docProc, dealHist2("deal_id") === docProc("deal_id")
                                    && dealHist2("cty_code") === docProc("cty_code"), "left")
                                .join(docAddl, docProc("cty_code") === docAddl("cty_code")
                                    && docProc("deal_id") === docAddl("deal_id") 
                                    && docProc("doc_id") === docAddl("doc_id"),"left")
                                .join(docShip, docProc("cty_code") === docShip("cty_code")
                                    && docProc("deal_id") === docShip("deal_id") 
                                    && docProc("doc_id") === docShip("doc_id"),"left")
                                .join(docKey, docProc("cty_code") === docKey("cty_code")
                                    && docProc("deal_id") === docKey("deal_id") 
                                    && docProc("doc_id") === docKey("doc_id"),"left")
                                .join(party, dealHist2("deal_rec_id") === party("deal_rec_id")
                                  && dealHist2("ct_pty_Id") === party("party_id"), "left")
                 
          //joining otp and sci data
          LOGGER.info("Joining otp and sci tables data")
          val otpSciJoin = otpdata.join(scidata, otpdata("cust_id") === scidata("lsx_ext_sys_cust_id")
                                   && scidata.col("lsx_ext_sys_cd_val") === "OAF" && scidata.col("bkl_cntry_iso_cd") === country, "left")
  
          //joining with resulted data with currency and rate table
          LOGGER.info("Joining resulted data with surrency and rate table")                                   
          val invoiceData = otpSciJoin.join(mainprof, otpSciJoin("lsx_le_id") === mainprof("lmp_sys_gen_le_id"), "left")
                                      .join(groupRates, docProc("doc_ccy_code") === groupRates("sc_cury") 
                                          && groupRates.col("row_num") === 1,"left")
                                      .join(cmtData, scidata("lsx_le_id") === cmtData("le_id") 
                        								&& scidata.col("lsx_ext_sys_cd_val") === "OAF" && scidata.col("bkl_cntry_iso_cd") === country, "left")
                        							.where(dealHist2.col("rel_seq_no").between(docProc.col("from_seq_no"), coalesce(docProc.col("to_seq_no"), dealHist2.col("rel_seq_no")))
                                    		&& dealHist2.col("rel_seq_no").between(docAddl.col("from_seq_no"), coalesce(docAddl.col("to_seq_no"), dealHist2.col("rel_seq_no")))
                                    	  && dealHist2.col("rel_seq_no").between(docKey.col("from_seq_no"), coalesce(docKey.col("to_seq_no"), dealHist2.col("rel_seq_no")))
                                    		&& dealHist2.col("rel_seq_no").between(docShip.col("from_seq_no"), coalesce(docShip.col("to_seq_no"), dealHist2.col("rel_seq_no")))
                                    		&& dealHist2.col("row_num") === 1)
                        		
                        								
        //this step will select only required columns
        LOGGER.info("selecting only required columns")        
        val finalData2 = invoiceData.select(dealHist2.col("cust_id"), 
                       concat(scidata.col("lsx_le_id"), lit("-"), scidata.col("lsx_lsp_id")),
                       scidata.col("lsx_ext_sys_cust_nm"), 
                       mainprof.col("lmp_new_segmt_val"), 
                       mainprof.col("lmp_sub_sgmnt_cd_val"), 
                       dealHist2.col("supplier_id"), 
                       dealHist2.col("buyer_id"), 
                       dealHist2.col("product_code"),
                       substring(dealHist2.col("value_date"),0,10),
                       substring(dealHist2.col("business_date"),0,10), 
                       docAddl.col("deal_id"),
                       docProc.col("doc_id"), 
                       docAddl.col("supplier_doc_no").alias("invoice_reference"), 
                       docAddl("invoice_date"), 
                       docProc.col("doc_ccy_code"), 
                       docProc.col("doc_ccy_amt"), 
                       groupRates.col("sc_cash"), 
                       when(docProc.col("doc_ccy_code") === "USD", docProc.col("doc_ccy_amt")).otherwise(docProc.col("doc_ccy_amt") / coalesce(groupRates.col("sc_cash"),lit(1))).alias("invoice_amount_usd"),
                       docKey.col("doc_type_code"), 
                       docShip.col("ship_mode"), 
                       docShip.col("Ship_doc_type_code"), 
                       docShip.col("ship_doc_no"), 
                       docShip.col("ship_date"), 
                       docShip.col("ship_from_cty_code"), 
                       docShip.col("ship_to_cty_code"), 
                       docShip.col("vessel_id"), 
                       docShip.col("goods_desc"), 
                       dealHist2.col("ct_pty_Id"), 
                       party.col("party_name"),
                       row_number().over(Window.partitionBy(dealHist2.col("supplier_id"), docAddl.col("supplier_doc_no"), dealHist2.col("buyer_id")).orderBy(docProc.col("doc_id").asc)).alias("submission_num"),
                       cmtData.col("sc_final_appr_crg").alias("credit_grade"), 
                       lit("XXXXXXXXXX").alias("alert_type"),
                       docAddl.col("tenor"),
                       dealHist2.col("mode_of_submission"),
                       dealHist2.col("step_code"),
                       dealHist2.col("pool_based_flag"), 
                       dealHist2.col("sale_ledger_flag"),
                       lit(space).alias("invoice_pattern"),
                       lit(zero).alias("pattern_count"),
                       dealHist2.col("report_mth"), 
                       lit(cty2).alias("cty")).distinct()   
                       
                       return (finalData2) 
      }
      
      
      //fetch country level data
      def fetchOtpCountryData(country:String, hc:HiveContext): otpAllData = {
        
        LOGGER.info("preparing variables for country specific table")
        
        val histTable = "stg_otp_"+country+histortyTable
        val docDtlsTable = "stg_otp_"+country+docDetailsTable
        val partyTable = "stg_otp_"+country+prtyTable
        val docProcTable = "stg_otp_"+country+docProcDtls
        val docAddlTable = "stg_otp_"+country+docAddlDtls
        val docShipTable = "stg_otp_"+country+docShipDtls
        val docKeyTable = "stg_otp_"+country+docKeyDtls
        
        val conutryUpper = country.toUpperCase()
        var cty2 = conutryUpper
        
        if( conutryUpper == "SP" ) {
           cty2 = "SG" 
        } else {
           cty2 = conutryUpper
          }
        
        //fetch max date for country tables
        var dfabPartitionDate = fetchMaxDate(dfabSchema, histTable, prevmonthbeg, prevmonthend, hc)
        
        val dealHist1 = hc.sql(s"""select  
                                    cty_code,
                                    cust_id, 
                                    supplier_id, 
                                    buyer_id, 
                                    product_code, 
                                    last_day(substr(value_date,0,10)) as report_mth,
                                    value_date,
                                    business_date, 
                                    deal_id, 
                                    deal_rec_id, 
                                    initiator_role_code, 
                                    txn_ccy_amt,
                                    txn_ccy_code, 
                                    product_type, 
                                    step_code, 
                                    pool_based_flag, 
                                    sale_ledger_flag, 
                                    rel_seq_no,
                                    case when cust_id = supplier_id then buyer_id else supplier_id end as ct_pty_Id,
                                    presentation_mode_code as mode_of_submission,
                                    ods
                             from ${dfabSchema}.${histTable} 
                             where ods='${dfabPartitionDate}'   and cty_code='${conutryUpper}' and step_status_code='03'
                               and step_code in ('NEW','RFF')   and product_type = 'TR'  and PRODUCT_CODE in ('IFNB','IFNS')  
                               and (substr(value_date,0,10) >= '${valueStartDate}' and substr(value_date,0,10) <= '${valueEndDate}')
                               """)
                                                              
                val dealHist2 = hc.sql(s"""select
                                        cty_code,
                                        cust_id, 
                                        supplier_id, 
                                        buyer_id, 
                                        product_code, 
                                        last_day(substr(value_date,0,10)) as report_mth,
                                        value_date,
                                        business_date, 
                                        deal_id, 
                                        deal_rec_id, 
                                        initiator_role_code, 
                                        txn_ccy_amt,
                                        txn_ccy_code, 
                                        product_type, 
                                        step_code, 
                                        pool_based_flag, 
                                        sale_ledger_flag, 
                                        rel_seq_no,
                                        case when cust_id = supplier_id then buyer_id else supplier_id end as ct_pty_Id,
                                        row_number() over (partition by deal_id  order by rel_seq_no desc) as row_num,
                                        presentation_mode_code as mode_of_submission,
                                        ods
                             from ${dfabSchema}.${histTable} 
                             where ods='${dfabPartitionDate}'   and cty_code='${conutryUpper}' and step_status_code='03'
                               and step_code in ('NEW','RFF')   and product_code in ('IFNB','IFNS')  
                               and (substr(value_date,0,10) >= '${valueStartDate}' and substr(value_date,0,10) <= '${valueEndDate}')
                               and sale_ledger_flag = 'Y'""")
                               
        val docProc = hc.sql(s"""select doc_id, 
