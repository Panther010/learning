      def fetchMaxDate (schema: String, table: String, prevmonthbeg: String, prevmonthend: String, hc:HiveContext) : String ={
        
        var maxDate = ""
        
        try {
          
           maxDate = hc.sql(s"""select max(ods) from ${schema}.${table} where ods >= '${prevmonthbeg}' and ods <= '${prevmonthend}'""").collect().map(_.getString(0)).mkString(" ")
           println(s"$maxDate + $schema + $table")
          
        } catch {
          case unknown: Exception => {
            LOGGER.error(s"Failing while feching maxDate from $schema.$table: $unknown")
            exit(1)            
          }
        }
        
        return maxDate
        
      }
      

      val sc = new SparkContext(conf)
      val sqlContext = new org.apache.spark.sql.SQLContext(sc)
      val hc = new HiveContext(sc) 
      
      hc.setConf("hive.exec.dynamic.partition.mode", "nonstrict")
      hc.setConf("hive.exec.dynamic.partition", "true")
      LOGGER.info("preparing query to fetch data from hive tables")
      
      val glbData = fetchGlobaldata(hc)
      
      val scidata = glbData._1.cache()
            
      checkCount(scidata , "scidata")
  
      val mainprof = glbData._2.cache()
      
      checkCount(mainprof , "mainprof")
      
      val groupRates = glbData._3.cache()
      
      checkCount(mainprof , "mainprof")
      
      val cmtData = glbData._4.cache()
      
      checkCount(cmtData , "cmtData")
      
      val histData = glbData._5.cache()
      
      checkCount(histData, "histData")
        
      val globaldata = (scidata, mainprof, groupRates, cmtData)
        
      //read country file 
      val countryList = Source.fromFile(file)

      LOGGER.info("running country wise data load")
      
      for (country <- countryList.getLines()){
        
        val otpCountryData = fetchOtpCountryData(country, hc)
        
        val joinData1 = joinGlobalCountryData1(otpCountryData._1, globaldata, country)
        
        val joinData2 = joinGlobalCountryData2(otpCountryData._2, globaldata, country)
        val totalData = joinData1.unionAll(joinData2).filter(col("submission_num") === 1)
        
        var ctyCode = country.toUpperCase()
        if( country == "SP" ) {
          ctyCode = "SG" 
          } else {
            ctyCode = country.toUpperCase()
            }
        
        val histCountry = histData.filter(col("cty") === ctyCode)
        
        totalData.registerTempTable("totalData")
        histCountry.registerTempTable("histCountry")
        
        val totalDataNoDup = hc.sql("select a.* from totalData a left join histCountry b on a.cty = b.cty and a.buyer_id = b.buyer_id and a.supplier_id = b.supplier_id and a.invoice_reference = b.invoice_reference where b.invoice_reference is null and b.supplier_id is null and b.buyer_id is null")
        
        //loading data to staging invoice table
        try {
          if (country.toUpperCase() == "SG" ) {
            
            totalDataNoDup.coalesce(5).write.partitionBy("report_mth", "cty").mode("append").insertInto(targetSchema+"."+targetTable)
            
            } else {
              
              totalDataNoDup.coalesce(5).write.partitionBy("report_mth", "cty").mode("overwrite").insertInto(targetSchema+"."+targetTable)
              
            }
          } catch {
           case unknown: Exception => { 
            LOGGER.error(s"Failing while inserting into T3 table: $unknown")
           exit(1)
           }
        } finally {
             LOGGER.info("successfully loaded data for  " + country + " country ")
           }
      }
        
    }
}
