                                        ods, 
                                        cty_code
                                  from ${dfabSchema}.${partyTable}
                                  where ods = '${dfabPartitionDate}' and cty_code='${conutryUpper}'""")
        
         return((dealHist1, docDtls, party),(dealHist2, docProc, docAddl, docShip, docKey, party))
      }
      
      
      //fetch global data
      def fetchGlobaldata(hc:HiveContext): globalData = {
        
        val sciPartitionDate = fetchMaxDate(sciSchema, xrefTable, prevmonthbegSci, prevmonthendSci, hc)
        
        val xref = hc.sql(s"""select lsx_ext_sys_cust_id, 
                                     lsx_ext_sys_cd_val, 
                                     lsx_ext_sys_cust_nm, 
                                     lsx_le_id, lsx_lsp_id, 
                                     ods, 
                                     lsx_bkg_loctn_id
                                   from ${sciSchema}.${xrefTable}
                                   where ods = '${sciPartitionDate}'""")
                                   
        val bkgloc = hc.sql(s"""select bkl_sys_gen_bkg_loctn_id, 
                                       bkl_cntry_iso_cd, ods
                                   from ${sciSchema}.${bklogTable}
                                   where ods = '${sciPartitionDate}'""")
                                   
        val mainprof = hc.sql(s"""select lmp_new_segmt_val, 
                                         lmp_sub_sgmnt_cd_val, 
                                         ods, 
                                         lmp_sys_gen_le_id
                                   from ${sciSchema}.${mainprofTable}
                                   where ods = '${sciPartitionDate}'""")
                                   
        //fetch max date for country tables
        var grouprateDate = fetchMaxDate(cibDrSchema, groupRateTable, prevmonthbeg, prevmonthend, hc)
                                          
        val groupRates = hc.sql(s"""select sc_cash, 
                                           sc_cury,
                                           row_number() over (PARTITION BY sc_cury ORDER BY dt1 desc) row_num,
                                           dt1  
                                    from ${cibDrSchema}.${groupRateTable} 
                                    where ods = '${grouprateDate}' and sc_cury_2 = 'USD'""")

//        val scoreCard = hc.sql(s"""select distinct sc_final_appr_crg,sc_approved_date,cr_cust_id
                                    
        val cmtPartition = fetchMaxDate(cmtSchema, cmtTable, prevmonthbeg, prevmonthend, hc)
                                    
        val scoreCard = hc.sql(s""" select distinct sc_final_appr_crg,cr_cust_id
                                    from ${cmtSchema}.${cmtTable} 
                                   where ods ='${cmtPartition}' and sc_status='2' and sc_approved_date is not null and sc_final_appr_crg is not null""")
                                   
        val custTxn = hc.sql(s"""select distinct cr_cust_id, substring(cr_cust_le_id, 1,8) as le_id 
                                 from ${cmtSchema}.${cmtCustTxnTable} 
                                 where ods = '${cmtPartition}'""")

        val scidata = xref.join(bkgloc, xref("lsx_bkg_loctn_id") === bkgloc("bkl_sys_gen_bkg_loctn_id"))
        
        val cmtdata = custTxn.join(scoreCard, custTxn("cr_cust_id") === scoreCard("cr_cust_id"), "left")
        
        val historyData = hc.sql(s"select distinct cty, buyer_id, supplier_id, invoice_reference from ${targetSchema}.${targetTable} where report_mth < '${historyMonthEnd}'")

        return (scidata, mainprof, groupRates, cmtdata, historyData)
        
      }
      
