		// dateFormat._1 = DATE VALUE
		// dateFormat._2 = DATE PATTERN
		//alphabet pattern find
		//find the match of date format within invoice
		if (invoice_trim.indexOfSlice(dateFormat._1.toUpperCase)>=0){
			val all_startIndex = 0.until(invoice_trim.length).filter(invoice_trim.startsWith(dateFormat._1.toUpperCase, _)).mkString(",").split(",")
			if (all_startIndex.size >0){
				val temp_AN = "[a-zA-Z]".r replaceAllIn(temp_pattern, "A")
				temp_pattern = "[0-9]".r replaceAllIn(temp_AN,"x")
				
				for (startIndex1 <- all_startIndex) {
					var temp_var = temp_pattern
					val dFormat = dateFormat._2
					val dateLen = dateFormat._1.length
					all_temp_patterns += "|"
					
					// date pattern find
					//val startIndex1 = invoice_trim.indexOfSlice(dateFormat._1.toUpperCase)
					if (startIndex1 ==0){
					   temp_var = dFormat + temp_var.substring(dateFormat._1.length,temp_var.length)+","+startIndex1+","+dFormat+","+dateFormat._1
					}else{
					   val temp_pattern1 = temp_var.substring(0,startIndex1.toInt) + dFormat
					   temp_var = temp_pattern1 + temp_var.substring(startIndex1.toInt+dateFormat._1.length, temp_var.length)+","+startIndex1+","+dFormat+","+dateFormat._1
					}
					temp_pattern = temp_var

					all_temp_patterns += temp_pattern
				}
			}
	}
}
return all_temp_patterns
}

def final_pattern_with_date(invoice_pattern:String): String ={
//function that transforms date format into "DATE" - one constant value for date pattern
//return final tranformed string

//check char by char in invoice_pattern
//current index
//replce date_index to current index with DATE
//concat string and return
var curr_index = 0
var final_date_pattern = ""
if (invoice_pattern!= null){
	val inv_length = invoice_pattern.length()
	//var date_count = 0
	invoice_pattern.foreach{chars =>
		if (chars == 'x'){
			final_date_pattern += "x"
		}else if (chars == 'A'){
			final_date_pattern += "A"
		}else{
			if (inv_length-1 == curr_index){
				final_date_pattern += "DATE"
			}else if(inv_length-1 != curr_index){
				if (invoice_pattern(curr_index+1) =='x' ||invoice_pattern(curr_index+1) =='A'){
					final_date_pattern += "DATE"
				}
			}
		}
		curr_index += 1
	}
}
return final_date_pattern
}

