def toRoman(n: Int): String ={
// function to convert integer to roman numeral
// use for date formatting
var roman = ""
if (n < 4)
	roman = "I"*n
else if (n==4)
	roman =  "IV"
else if (n >4 && n<9)
	roman = "V"+ ("I"*(n-5))
else if (n == 9)
	roman = "IX"
else if (n > 9 && n < 13)
	 roman = "X" + "I"*(n-9)
return roman
} 

def pattern_grp(initial_pattern:String): List[(String,Int)]={
// function to group consecutive same characters in String and tag the count
// return a list of paired values
// each pair contains the Character and it's occurance count consecutively

//does not register symbols
var initial_group = List[(String,Int)]()
val regexp =  "[A]+|[x]+|[r]+|FIYR|FINCYR|[M]+|[d]+|[y]+".r
val groups = regexp.findAllIn(initial_pattern).toArray   
	
for (i <- groups.size-1 to 0 by -1){
	var ret = groups(i)
	var size = groups(i).size
	if (groups(i)(0)=='A'|| groups(i)(0)=='x'||groups(i)(0)=='d'|| groups(i)(0)=='M'|| groups(i)(0)=='y'|| groups(i)(0)=='r')
		ret = groups(i)(0).toString
	if (groups(i)=="FIYR"|| groups(i)=="FINCYR")
		size = 1
	initial_group ::= (ret, size)
}
return initial_group
}

def final_pattern(doc_no:String, date_pattern:String): String={ 
//function to transform different parts of the invoice into "A"s,"x"x and Date format
//return the transformed value
var temp_final = ""   
	   
if(date_pattern.contains(",")){
	val splited = date_pattern.split(",")
	val date_ptn_grp = pattern_grp(splited(0))
	
	date_ptn_grp.foreach{x =>        
		if (x._1 =="x"){
			temp_final +="xxxx"
		}else if (x._1 == "A") {
			temp_final +="A"*x._2
		}else if (x._1 == "FINCYR") {
			temp_final +="FINCYR"
		}else if (x._1 == "FIYR") {
			temp_final +="FIYR"
		}else if (x._1 == "d") {
			temp_final +="d"*x._2
		}else if (x._1 == "M") {
			temp_final +="M"*x._2
		}else if (x._1 == "y") {
			temp_final +="y"*x._2
		}else if (x._1 == "r") {
			temp_final +="r"*x._2
		}else{
			temp_final += ""
		}
	}
}else {
	val ptn_grp = pattern_grp(date_pattern)    
	ptn_grp.foreach{x =>        
		if (x._1 =="x"){
			temp_final +="xxxx"
		}else if (x._1 == "A") {
			temp_final +="A"*x._2
		}else{
			temp_final += ""
		}
	}
}
return temp_final
}


