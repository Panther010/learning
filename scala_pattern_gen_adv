def fetchArray (arrayName:Array[String], index:Int): String={
var data = ""
try{
data = arrayName(index)
} catch {
case unknown: Exception => {
data = fetchArray(arrayName, (index -1))
}
}
return data
}

val replaceSymbols = regex replaceAllIn(invoice.toUpperCase(),"")
val initial_pattern = "[0-9]".r replaceAllIn(replaceSymbols, "x")

val regexp =  "[A-Z]+|[a-z]+".r
val groups = regexp.findAllIn(initial_pattern).toArray  

val regexp2 =  "[A]+|MM+|MMM+|MMMM+|FIYR+|FINCYR+|[a-z]+".r
val groups2 = regexp2.findAllIn(invoice_patter).toArray 

var alphaPattern = ""
var j = 0
for (i <- 0 to groups2.size-1 by 1){
if (groups2(i).contains("A")) {
alphaPattern += fetchArray(groups, (i-j))
} else {
if (groups2(i).contains("MM") || groups2(i).contains("FIYR") || groups2(i).contains("FINCYR") || groups2(i).contains("yy")) {
if (j >= groups2.size - groups.size) {
j = j} else {j += 1}
alphaPattern += fetchArray(groups2, i)
} else
alphaPattern += fetchArray(groups2, i)}
}
return alphaPattern
}

