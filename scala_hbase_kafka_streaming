  def setupStreamPipeline(
    brokerlist: String,
    proposedtopic: String,
    country: String,
    revisedtopic: String,
    frequency: Int,
    debug: Int,
    envConfig: EnvConfig): StreamingContext = {

    //val sparkConf = new SparkConf().setAppName(ContactHistory.appName).setMaster("local[*]")
    val sparkConf = new SparkConf().setAppName(ContactHistory.appName)
    
    /*sparkConf.set("spark.serializer", "org.apache.spark.serializer.KryoSerializer")
    sparkConf.set("spark.kryoserializer.buffer.max", "1024m")
    sparkConf.set("spark.streaming.kafka.maxRatePerPartition", "5000")*/
    //sparkConf.registerKryoClasses(Array(classOf[CampaignOcrSetup]))
    //sparkConf.set("spark.hadoop.validateOutputSpecs", "true")
    
                   //sparkConf.registerKryoClasses(Array(classOf[SttKafkaInput],classOf[GiftIssueUpdate]))

    val streaming = new StreamingContext(sparkConf, Seconds(frequency))
    val sc = streaming.sparkContext

    //Creates required  HBase tables

    HBaseTables.create()

    val hbaseTables = new HBaseTables()
    val sysdate = CHHelper.y_m_dFn()
    val dhrconf = HBaseHelper.getHbaseConfiguration()

    /*
        //Opens Kafka partition counter hbase table to get last offset processed
        dhrconf.set(TableInputFormat.INPUT_TABLE, HBASE_COUNTER_TABLE)
        val topicsAndOffsets: scala.collection.immutable.Map[TopicAndPartition, Long] =
          sc.newAPIHadoopRDD(dhrconf, classOf[TableInputFormat],
            classOf[ImmutableBytesWritable],
            classOf[Result])
            .map(x => x._2)
            .map(result => (
              TopicAndPartition(
                HBaseHelper.getValue(result, HBASE_DEFAULT_CF, HBASE_COL_COUNTER_TOP),
                HBaseHelper.getValueAsInt(result, HBASE_DEFAULT_CF, HBASE_COL_COUNTER_KPART)),
                HBaseHelper.getValueAsLong(result, HBASE_DEFAULT_CF, HBASE_COL_COUNTER_NEXT)))
            .collectAsMap.toMap
            println("hbase read check point table - done")
        val kafkaParams = Map[String, String](
          "metadata.broker.list" -> brokerlist,
          "auto.offset.reset" -> "smallest")

        // Start the stream
        val messages: InputDStream[(String, String)] =
          if (topicsAndOffsets.isEmpty) {
            KafkaUtils.createDirectStream[String, String, StringDecoder, StringDecoder](
              streaming, kafkaParams, Set(proposedtopic))
          } else {
            KafkaUtils.createDirectStream[String, String, StringDecoder, StringDecoder, (String, String)](
              streaming, kafkaParams, topicsAndOffsets, (mmd: MessageAndMetadata[String, String]) => (mmd.key, mmd.message))
          }
        //messages.persist(StorageLevel.MEMORY_AND_DISK_2)*/

    val messages = StreamingHelper.getDirectstream(streaming,brokerlist,proposedtopic,HBASE_COUNTER_TABLE,MULTI_PARTITION_OFFSET_FLAG,"hk_ch_group")

    // Loads OCR setup configuration HBase table for campaign configuration
    dhrconf.set(TableInputFormat.INPUT_TABLE, HBASE_CH_CAMP_OCR_SETUP)
    val campaignOcrResultRDD = sc.newAPIHadoopRDD(dhrconf, classOf[TableInputFormat],
      classOf[ImmutableBytesWritable],
      classOf[Result])
      .map(x => CampaignOcrSetup(x._2))

    val campaignOcr = campaignOcrResultRDD
      .filter(x => x.active_flag == "Y")
      .map(x => (x.campaign_id, x)).collectAsMap

    envConfig.logInfo("CH: CampaignOcr setup done")
    envConfig.logInfo("CH: Total Campaign Loaded : "+campaignOcr.size)
    envConfig.logInfo("CH: Campaigns Details : "+campaignOcr)

    // Loads Counter configuration table
    dhrconf.set(TableInputFormat.INPUT_TABLE, HBASE_CH_COUNTER_CONF)

    val countersRDD = sc.newAPIHadoopRDD(dhrconf, classOf[TableInputFormat],
      classOf[ImmutableBytesWritable],
      classOf[Result])
      .map(x => Counters(x._2))

    val countersMap = countersRDD
      .map(x => (x.counter_name, x)).collectAsMap

    envConfig.logInfo("CH: CountersMap setup done")
    envConfig.logInfo("CH: Going to process Direct Stream")

    //logger.info("CH: Message count --> " + messages.count())
    //println("MESSAGES TO PRINT"+messages.count())
    messages.foreachRDD {
      rdd =>
        /*Executes at workers*/
        val offsetRanges = rdd.asInstanceOf[HasOffsetRanges].offsetRanges
        val nParts = rdd.partitions.size
        val cntrylower = "\"country\":\"" + country.toLowerCase() + "\""
        val cntryupper="\"country\":\"" + country.toUpperCase() + "\""
        val appnotify = "\"channel\":\"" + APP_NOTIFY + "\""
        /*logger.info("CH: Country" + cntrylower +"or"+cntryupper)
        logger.info("CH: Filtering channel which are not " + appnotify)*///tkp
        //println("RDD MESSAGES CHECK  >> :"+rdd.isEmpty())
        //println("RDD MESSAGES >> :"+rdd)
 // rdd.collect().foreach(println)
        val sgrdd = rdd.filter(x => ((x.value().contains(cntrylower)  || x.value().contains(cntryupper) ) && !x.value().contains(appnotify)))
        
        //println("SGD RDD MESSAGES >> :"+rdd)
               
        
       //sgrdd.collect().foreach(println)
        
       // logger.info("CH: Count of messages to be processed after Filtering for "+country+" country --> " + sgrdd.count()) 
        sgrdd.foreachPartition { sparkPartition =>
          if (!sparkPartition.isEmpty) {
            val currid = TaskContext.get.partitionId
            val osr: OffsetRange = offsetRanges(currid)
            val untilOffset = osr.untilOffset //exclusive
            val id = osr.partition
            val topic = osr.topic
              //println("Topic ----------------------> "+topic)

            envConfig.logInfo(s"CH: Going to process message in direct stream from Partition:id, Topic:$topic, FromOffset:$osr.fromOffset, TillOffset:$untilOffset ")

            val kafkaTopics = new KafkaTopics(brokerlist)
            val hbaseTables = new HBaseTables()
            sparkPartition.foreach { arr =>
              
              val parser = new JsonParser
              var json: com.google.gson.JsonObject = null
              var valid_json = true
              //Checks whether input Json is in correct format
              try {
                json = parser.parse(arr.value()).getAsJsonObject
              } catch {
                case ex: Exception => {
                  ex.printStackTrace()
                  valid_json = false
                }
              }

              //Process only valid Json
              envConfig.logInfo("CH: is input message a valid json ?? --> " + valid_json)
              if (valid_json) {

                try {
                  val msg = ProposedMessage(json)
                  envConfig.logInfo("CH: Parsed the input JSON as proposedContactRecord: "+msg)
                  var reason=SUCCESS_REASON
                  /*logger.info("Country :::::" + msg.country)
                  logger.info("TrackingId:::" + msg.referenceId)
                  println("TrackingId:"+msg.referenceId)*/
                  var approved = false
                  val actionId = msg.actionId

                  var campDetails: CampaignOcrSetup = new CampaignOcrSetup("", "", "", "", "", "", "", "", "", "", "","")
                  //println("CH: Campaign ID OR Offer ID -->" + msg.offerId)
                  //Checks whether campaign is active or not using offerId received in input Json against campaign configuration details
                  envConfig.logInfo("CH: Campaign ID OR Offer ID -->" + msg.offerId)
                  envConfig.logInfo("CH: Action ID of the Campaign -->" + actionId)
                  envConfig.logInfo("CH: Channel the Campaign -->" + msg.channel)
                  
                  if (campaignOcr.keySet.contains(msg.offerId.trim())) {
                    campDetails = campaignOcr.get(msg.offerId.trim()).get
                    envConfig.logInfo("CH: Reason after Campaign activness --> ACTIVE CAMPAIGN")

                  } else {
                    reason = Some(ExclusionReason.CAMPAIGN_NOT_ACTIVE_IN_CONFIG).toString()
                    envConfig.logInfo("CH: Reason after Campaign activness -->" + reason)
                  }
                  
                  var uniqueId=""
                  if(msg.channel.trim().equals("mail"))
                      {
                        uniqueId=msg.trackingId
                      }
                  else
                  {
                      uniqueId=msg.referenceId
                  }
                  
                  val trackIdHash = HBaseHelper.getMurmerHashcode(uniqueId.concat(msg.offerId))

                  envConfig.logInfo("CH: Reference Id of the Message -->" + msg.referenceId)
                  envConfig.logInfo("CH: Trackning Id of the Message -->" + msg.trackingId)

                  envConfig.logInfo("CH: Hash Tracking ID :"+trackIdHash)

                  if (reason==SUCCESS_REASON) {
                    reason = Requirements.CampignLevelValidation(trackIdHash, hbaseTables, campDetails, json, msg).toString()
                    envConfig.logInfo("CH: Reason after Campign Level Validation check --> " + reason)
                  }

                  //Checks whether current message or transaction already received
                  if (reason==SUCCESS_REASON) {
                    reason = Requirements.DuplicateValidate(trackIdHash, msg, hbaseTables).toString()
                    envConfig.logInfo("CH: Reason after Duplicate check --> " + reason)
                  }

                  if (reason==SUCCESS_REASON) {

                    //Since current message or transaction is not duplicate make an entry in interaction log
                    //Read the counter to be incremented for this current campaign
                    //Requirements.CustomerLevelValidation(trackIdHash,msg, hbaseTables, campCounter )
                    //If first value in counters is SkipAll then send message to revised without any check and make an entry in message table.

                    hbaseTables.hInteractionLog.incrementColumnValue(Bytes.toBytes(trackIdHash), Bytes.toBytes(HBASE_DEFAULT_CF), Bytes.toBytes(HBASE_TXN_COUNT), 1)

                    reason = Requirements.campaignCustomerlevel(json, brokerlist, campDetails, hbaseTables, msg, trackIdHash, countersMap).toString()
                    envConfig.logInfo("CH: Reason after  Customer level check --> " + reason)


                    val perCampaignCounter = campDetails.per_campaign_counter.split(SPLIT_BY_COMMA)

                    if (reason==SUCCESS_REASON && perCampaignCounter(0) != NOT_APPLICABLE) {

                      reason = Requirements.perCampaignCounter(perCampaignCounter, hbaseTables, countersMap).toString()
                      envConfig.logInfo("CH: Reason after Campaign level check --> " + reason)

                    }

                    //If the reason is empty which tells the message is valid to be posted in revised topic
                    if (reason==SUCCESS_REASON) {

                      //Iterates through counters and increment live counters.
                      val campCounter = campDetails.campaign_level_counters.split(SPLIT_BY_COMMA)
                      campCounter.foreach { cntr =>
                        {
                          var relIn = Bytes.toBytes("")
                           if (campDetails.key_value.equalsIgnoreCase("Mobile No"))
                               relIn = Bytes.toBytes(msg.destination)
                           else 
                               relIn = Bytes.toBytes(msg.relId)
                          val exIncrement = new Increment(relIn)
                          exIncrement.addColumn(Bytes.toBytes(HBASE_DEFAULT_CF), Bytes.toBytes(cntr.trim()), INCREMENT_BY_ONE)
                          hbaseTables.hLiveCounters.increment(exIncrement)
                          envConfig.logInfo("CH: Incremented for  " + relIn + " referenceId= " + msg.referenceId)
                        }

                      }

                      
                      if (reason==SUCCESS_REASON && perCampaignCounter(0) != NOT_APPLICABLE)
                      {
                        perCampaignCounter.foreach { cntr =>
                        {
                          
                          val getCampigncounter = countersMap.get(cntr).get
                          if (!getCampigncounter.threshold_setup.toString().equalsIgnoreCase(THRESHHOLD_SETUP))
                          {
                          val key = Bytes.toBytes(PER_CAMPAIGN_COUNTER)
                          val exIncrement = new Increment(key)
                          exIncrement.addColumn(Bytes.toBytes(HBASE_DEFAULT_CF), Bytes.toBytes(cntr.trim()), INCREMENT_BY_ONE)
                          hbaseTables.hkChLiveCampaignCounters.increment(exIncrement)
                          envConfig.logInfo("CH: Incremented in "+HBASE_CH_LIVE_CAMPAIGN_COUNTERS)
                          }
                        }

                      }

                      }
                      
                      CampaignWindowAction.StatusApprove(json, brokerlist, campDetails, hbaseTables, trackIdHash,reason, msg)
                     

                    } else {
                      CampaignWindowAction.StatusReject(json, brokerlist, campDetails, hbaseTables, trackIdHash, reason, msg)
                    }

                  } else {
                    CampaignWindowAction.StatusReject(json, brokerlist, campDetails, hbaseTables, trackIdHash, reason, msg)

                  }

                } catch {
                  case ex: Exception => {
                    println("ERROR: " + ex.getMessage)
                    ex.printStackTrace()
                  }
                } finally {
                  //cm.close

                }

              }

            }

            val cPut = new Put(Bytes.toBytes(id))
            cPut.addColumn(CHHelper.default_b, Bytes.toBytes(HBASE_COL_COUNTER_KPART), Bytes.toBytes(id))
            cPut.addColumn(CHHelper.default_b, Bytes.toBytes(HBASE_COL_COUNTER_TOP), Bytes.toBytes(topic))
            cPut.addColumn(CHHelper.default_b, Bytes.toBytes(HBASE_COL_COUNTER_NEXT), Bytes.toBytes(untilOffset))
            hbaseTables.hCounter.put(cPut)

            hbaseTables.close
            envConfig.logInfo("CH: Processed Single Message")

          }

        }

    }

    sys.ShutdownHookThread {
      envConfig.logInfo("CH: Gracefully stopping Contact history application")
      streaming.stop(true, true)

    }
    streaming
  }

  def main(args: Array[String]) {

    val nargs = 5
    if (args.length < nargs) {
      System.err.println(s"""
                |Usage: contacthistory <input_topic> <country> <output_topic> <frequency> <debug_mode>
                """.stripMargin)
      System.exit(1)
    }

    val Array(proposedtopic, country, revisedtopic, frequency, debug) = args

    val envConfig = EnvConfig(CONTACT_HISTORY_MAIN_MODULE,debug.toInt)
    val brokerlist = envConfig.BROKER_LIST

    DEBUG = debug.toInt

    envConfig.logInfo(s"CH: Starting ContactHistory for country-$country with APP_NAME:$appName, INPUT_TOPIC:$proposedtopic, OUTPUT_TOPIC:$revisedtopic, STREAM_DURATION:$frequency, KAFKA_BROKER:$brokerlist")

/*
//tkp
    logger.info("Brokers: %s".format(brokerlist))
    logger.info("CCMS Topic: %s".format(proposedtopic))
    logger.info("country: %s".format(country))
    logger.info("revisedtopic: %s".format(revisedtopic))
    logger.info("Frequency: %s".format(frequency))
    //logger.info("properties_file_path: %s".format(properties_file))
*/
    var streaming = setupStreamPipeline(brokerlist, proposedtopic, country, revisedtopic, frequency.toInt, debug.toInt, envConfig: EnvConfig)
    //Start computation
   
    //logger.info("CH: Starting Streaming  Job ")
    streaming.start()
    streaming.awaitTermination()
     //logger.info("CH: Ver 07082044 ")

  }
}
